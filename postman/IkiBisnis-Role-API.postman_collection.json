              "name": "201 — Role berhasil dibuat",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin\",\n  \"description\": \"Admin\",\n  \"badgeColor\": \"#DC2626\",\n  \"permissions\": [{\"feature\": \"user_management_roles\", \"actions\": [\"read\",\"write\",\"update\",\"delete\"]}]\n}" },
                "url": { "raw": "{{base_url}}/api/v1/roles", "host": ["{{base_url}}"], "path": ["api", "v1", "roles"] }
              },
              "status": "Created",
