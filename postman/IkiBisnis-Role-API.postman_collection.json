      "item": [
        {
          "name": "1. Create Role — Finance Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "    pm.collectionVariables.set('role_id', res.data.id);",
                  "    console.log('✅ role_id tersimpan:', res.data.id);",
                  "}",
                  "",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response success true', () => pm.expect(res.success).to.be.true);",
                  "pm.test('Data memiliki id', () => pm.expect(res.data).to.have.property('id'));",
                  "pm.test('Nama sesuai', () => pm.expect(res.data.name).to.eql('Finance Manager'));",
                  "pm.test('Badge color sesuai', () => pm.expect(res.data.badgeColor).to.eql('#4F46E5'));",
                  "pm.test('Permissions tidak kosong', () => pm.expect(res.data.permissions).to.have.length.above(0));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Finance Manager\",\n  \"description\": \"Mengelola semua laporan keuangan perusahaan\",\n  \"badgeColor\": \"#4F46E5\",\n  \"permissions\": [\n    { \"feature\": \"dashboard\",         \"actions\": [\"read\"] },\n    { \"feature\": \"laporan_harian\",     \"actions\": [\"read\", \"write\"] },\n    { \"feature\": \"laporan_neraca\",     \"actions\": [\"read\"] },\n    { \"feature\": \"laporan_laba_rugi\",  \"actions\": [\"read\"] },\n    { \"feature\": \"laporan_arus_kas\",   \"actions\": [\"read\"] }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/roles",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "roles"]
            },
            "description": "Membuat role Finance Manager — akses ke semua laporan keuangan.\n\n**Features tersedia:**\n- `dashboard`\n- `user_management_roles`, `user_management_users`\n- `projects`\n- `penawaran`\n- `laporan_harian`, `laporan_neraca`, `laporan_laba_rugi`, `laporan_arus_kas`\n- `settings`\n\n**Actions tersedia:** `read`, `write`, `update`, `delete`"
          },
