          "name": "Info: Features, Actions & Permission Matrix",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/roles?page=1&limit=10",
